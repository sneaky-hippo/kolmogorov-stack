{
  "name": "kolm-vscode",
  "displayName": "Kolm — Compile your AI behavior into a signed file",
  "description": "Compile, inspect, verify, and run .kolm artifacts without leaving your editor. Detects LLM calls and offers to swap them for a signed, deterministic kolm artifact.",
  "version": "0.2.0",
  "publisher": "kolmogorov",
  "license": "Apache-2.0",
  "homepage": "https://kolm.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sneaky-hippo/kolmogorov-stack.git",
    "directory": "sdk/vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["AI", "Other", "Programming Languages"],
  "keywords": [
    "kolm",
    "kolmogorov",
    "llm",
    "claude",
    "openai",
    "anthropic",
    "artifact",
    "compile",
    "verify",
    "k-score",
    "receipt",
    ".kolm"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:python",
    "onCommand:kolm.inspect",
    "onCommand:kolm.verify",
    "onCommand:kolm.run",
    "onCommand:kolm.compile",
    "onCommand:kolm.search",
    "onCommand:kolm.openConsole",
    "onCommand:kolm.replaceLLMCall"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      { "command": "kolm.inspect",         "title": "Kolm: Inspect this .kolm artifact" },
      { "command": "kolm.verify",          "title": "Kolm: Verify this .kolm artifact" },
      { "command": "kolm.run",             "title": "Kolm: Run a .kolm artifact with an input" },
      { "command": "kolm.compile",         "title": "Kolm: Compile a new artifact from a spec" },
      { "command": "kolm.search",          "title": "Kolm: Search the public registry" },
      { "command": "kolm.replaceLLMCall",  "title": "Kolm: Replace this LLM call with a kolm artifact" },
      { "command": "kolm.openConsole",     "title": "Kolm: Open the dashboard" }
    ],
    "menus": {
      "editor/context": [
        { "command": "kolm.replaceLLMCall", "group": "1_modification", "when": "editorHasSelection" }
      ],
      "explorer/context": [
        { "command": "kolm.inspect", "when": "resourceExtname == .kolm", "group": "navigation" },
        { "command": "kolm.verify",  "when": "resourceExtname == .kolm", "group": "navigation" },
        { "command": "kolm.run",     "when": "resourceExtname == .kolm", "group": "navigation" }
      ]
    },
    "configuration": {
      "title": "Kolm",
      "properties": {
        "kolm.apiKey": {
          "type": "string",
          "default": "",
          "description": "Kolm API key (ks_...). Get one at https://kolm.ai/signup. Falls back to KOLM_API_KEY env var."
        },
        "kolm.baseUrl": {
          "type": "string",
          "default": "https://kolm.ai",
          "description": "Kolm API base URL. Default points at the hosted service."
        },
        "kolm.suggestReplacements": {
          "type": "boolean",
          "default": true,
          "description": "Show inline CodeLens suggestions on detected LLM calls."
        },
        "kolm.showRestEquivalent": {
          "type": "boolean",
          "default": true,
          "description": "After running a command, log the equivalent REST call so the editor doubles as an API tutorial."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "echo 'no-op'",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0"
  }
}
