      "id": "rcp_icd10_cpt_crosswalk_v1",
      "name": "icd10-cpt-crosswalk",
      "class": "rule",
      "source": "function generate(input,lib){var i=input||{},r=(lib&&lib.pack&&lib.pack.rules)||{};var I=r.icd_to_cpt_seed||{},C=r.cpt_to_icd_seed||{};var m=String(i.mode||'');var q='',M=[];if(m==='icd_to_cpt'){q=String(i.icd10||'');var arr=I[q]||[];for(var a=0;a<arr.length;a++){var e=arr[a]||{};M.push({code:String(e.cpt||''),description:String(e.description||''),strength:String(e.strength||'optional'),basis:String(e.basis||'ama_cpt_guidelines')});}}else if(m==='cpt_to_icd'){q=String(i.cpt||'');var brr=C[q]||[];for(var b=0;b<brr.length;b++){var f=brr[b]||{};M.push({code:String(f.icd10||''),description:String(f.description||''),strength:String(f.strength||'optional'),basis:String(f.basis||'ama_cpt_guidelines')});}}return {mode:m,query:q,matches:M};}",
      "tags": ["health-insurance", "icd-10", "cpt", "crosswalk", "lookup", "rule"],
      "schema": {
        "input": { "mode": "string", "icd10": "string", "cpt": "string" },
        "output": { "mode": "string", "query": "string", "matches": "array" }
      }
