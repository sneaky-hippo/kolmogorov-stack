      "source": "function generate(i,lib){var t=(i&&i.edi_text)||'',AC=((lib.pack||{}).rules||{}).aaa_reject_codes||{},S=t.split('~'),F=null,D=null,p={},pr={},sb={},Q=null,RS=null,E=[];for(var k=0;k<S.length;k++){var f=S[k].trim().split('*'),x=f[0];if(x=='ST'){F=f[1];D=f[1]=='270'?'inquiry':'response';if(D=='inquiry')Q={service_type_codes:[],date_of_service:null};else RS={eligibility:'pending',benefits:[],errors:E};}else if(x=='NM1'){var q=f[1];if(q=='PR'){p.name=f[3];p.payer_id=f[9];}else if(q=='1P'||q=='85'){pr.name=f[3];pr.npi=f[9];}else if(q=='IL'){sb.name='<redacted>';sb.redacted_member_id='<hash>';}}else if(x=='REF'&&f[1]=='6P')sb.group_number=f[2];else if(x=='DMG')sb.dob='<redacted>';else if(x=='DTP'&&f[1]=='291'&&Q)Q.date_of_service=f[3];else if(x=='EQ'&&Q)Q.service_type_codes.push(f[1]);else if(x=='EB'&&RS){var v='123'.indexOf(f[1])>=0?'active':'678'.indexOf(f[1])>=0?'inactive':null;if(v)RS.eligibility=v;RS.benefits.push({service_type_code:f[3]||null,coverage_level:f[2]||null,monetary_amount:+f[7]||null});}else if(x=='AAA')E.push({code:f[3]||null,description:AC[f[3]]||null});}var o={format:F,direction:D,payer:p,provider:pr,subscriber:sb};if(Q)o.inquiry=Q;if(RS)o.response=RS;return o;}",
      "tags": ["health-insurance", "edi", "270", "271", "eligibility", "x12", "5010"],
