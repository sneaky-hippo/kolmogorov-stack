  "recipes": [
    {
      "id": "rcp_edi_835_v1",
      "name": "edi-835",
      "source": "function generate(i,l){var S=((i&&i.edi_text)||'').split(/~\\s*/),V=function(s){return s||null},F=function(s){return parseFloat(s)||0},p={method:null,total_amount:0,trace_number:null,payment_date:null},pr={name:null,npi:null},pe={name:null,npi:null,tax_id:null},cl=[],pa=[],c=null,x,w,sc=0,sp=0;for(x=0;x<S.length;x++){var f=S[x].split('*'),T=f[0],q=f[1],r=f[2],s=f[3],u=f[4];if(T==='BPR')p.method=V(u),p.total_amount=F(r);else if(T==='TRN')p.trace_number=V(r);else if(T==='DTM'&&q==='405')p.payment_date=V(r);else if(T==='N1'&&(w=q==='PR'?pr:q==='PE'?pe:0)){w.name=V(r);if(s==='XX')w.npi=V(u);else if(s==='FI'&&w===pe)w.tax_id=V(u);}else if(T==='CLP')cl.push(c={claim_control_number:V(q),status_code:V(r),total_charge:F(s),total_paid:F(u),patient_responsibility:F(f[5]),adjustments:[]}),sc+=F(u);else if(T==='CAS'&&c)c.adjustments.push({group_code:V(q),reason_code:V(r),amount:F(s)});else if(T==='PLB')pa.push({provider_id:V(q),reason_code:V(s),amount:F(u)}),sp-=F(u);}var ct=Math.round((sc+sp)*100)/100,d=p.total_amount;return{format:'835',payer:pr,payee:pe,payment:p,claims:cl,provider_adjustments:pa,balance_check:{computed_total:ct,declared_total:d,balanced:Math.abs(ct-d)<0.01}};}",
      "tags": ["health-insurance", "edi", "835", "remittance", "era", "payment", "x12", "5010"],
      "schema": {
        "input": { "edi_text": "string" },
        "output": {
          "format": "string",
          "payer": "object",
          "payee": "object",
          "payment": "object",
          "claims": "array",
          "provider_adjustments": "array",
          "balance_check": "object"
        }
      }
    }
  ],
