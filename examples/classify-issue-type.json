{
  "name": "classify-issue-type",
  "description": "Triages support issues by type: bug, feature, billing, account.",
  "tags": ["classifier", "support", "triage"],
  "visibility": "public",
  "output_spec": { "type": "enum", "values": ["bug", "feature", "billing", "account"] },
  "positives": [
    { "input": "the app crashes when I click submit", "expected": "bug" },
    { "input": "page returns 500 error every time", "expected": "bug" },
    { "input": "broken on safari mobile", "expected": "bug" },
    { "input": "would love a dark mode option", "expected": "feature" },
    { "input": "could you add csv export", "expected": "feature" },
    { "input": "any plans for an api integration", "expected": "feature" },
    { "input": "charged twice for last month", "expected": "billing" },
    { "input": "want to upgrade my plan", "expected": "billing" },
    { "input": "refund for cancelled subscription", "expected": "billing" },
    { "input": "cant log in to my account", "expected": "account" },
    { "input": "forgot password and reset broken", "expected": "account" },
    { "input": "need to change my email address", "expected": "account" }
  ]
}
