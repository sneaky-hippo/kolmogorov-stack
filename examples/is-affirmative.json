{
  "name": "is-affirmative",
  "description": "Detects yes / agreement responses vs no / negative.",
  "tags": ["classifier", "intent"],
  "visibility": "public",
  "output_spec": { "type": "boolean" },
  "positives": [
    { "input": "yes please", "expected": true },
    { "input": "yep that works", "expected": true },
    { "input": "sure thing", "expected": true },
    { "input": "absolutely agreed", "expected": true },
    { "input": "ok go ahead", "expected": true },
    { "input": "sounds good", "expected": true },
    { "input": "no thanks", "expected": false },
    { "input": "nope cant make it", "expected": false },
    { "input": "never mind drop it", "expected": false },
    { "input": "decline this please", "expected": false },
    { "input": "reject the proposal", "expected": false }
  ]
}
