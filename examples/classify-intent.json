{
  "name": "classify-intent",
  "description": "Three-way customer-message intent classifier.",
  "tags": ["classifier", "demo", "intent"],
  "visibility": "public",
  "output_spec": { "type": "enum", "values": ["greeting", "question", "complaint"] },
  "positives": [
    { "input": "hi how are you", "expected": "greeting" },
    { "input": "hello there", "expected": "greeting" },
    { "input": "good morning", "expected": "greeting" },
    { "input": "what time does it open", "expected": "question" },
    { "input": "where is my order", "expected": "question" },
    { "input": "how do I reset my password", "expected": "question" },
    { "input": "this is broken", "expected": "complaint" },
    { "input": "doesnt work and im angry", "expected": "complaint" },
    { "input": "refund please", "expected": "complaint" }
  ],
  "negatives": []
}
