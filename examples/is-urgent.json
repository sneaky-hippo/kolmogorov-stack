{
  "name": "is-urgent",
  "description": "Flags messages that signal urgency.",
  "tags": ["classifier", "priority", "moderation"],
  "visibility": "public",
  "output_spec": { "type": "boolean" },
  "positives": [
    { "input": "urgent please respond ASAP", "expected": true },
    { "input": "site is down right now", "expected": true },
    { "input": "critical bug in production", "expected": true },
    { "input": "PLEASE help immediately", "expected": true },
    { "input": "emergency rollback needed", "expected": true },
    { "input": "drop everything fire alarm", "expected": true },
    { "input": "lunch tomorrow at noon", "expected": false },
    { "input": "review when you have time", "expected": false },
    { "input": "nice work on the launch", "expected": false },
    { "input": "scheduling a sync next week", "expected": false }
  ]
}
