{
  "name": "is-thank-you",
  "description": "Detects gratitude expressions in messages.",
  "tags": ["classifier", "intent", "csat"],
  "visibility": "public",
  "output_spec": { "type": "boolean" },
  "positives": [
    { "input": "thanks for the quick fix", "expected": true },
    { "input": "thank you so much", "expected": true },
    { "input": "appreciate the help", "expected": true },
    { "input": "thx team", "expected": true },
    { "input": "much appreciated", "expected": true },
    { "input": "grateful for the response", "expected": true },
    { "input": "this is broken", "expected": false },
    { "input": "where is my order", "expected": false },
    { "input": "ship it", "expected": false },
    { "input": "deploy at 3pm", "expected": false }
  ]
}
