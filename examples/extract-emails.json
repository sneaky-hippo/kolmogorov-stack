{
  "name": "extract-emails",
  "description": "Pulls every email address out of free text.",
  "tags": ["extractor", "demo", "text"],
  "visibility": "public",
  "output_spec": { "type": "string[]", "pattern": "email" },
  "positives": [
    { "input": "ping me at hello@kolm.ai or hi@example.com", "expected": ["hello@kolm.ai", "hi@example.com"] },
    { "input": "no email here", "expected": [] },
    { "input": "support@acme.co for sales", "expected": ["support@acme.co"] }
  ],
  "negatives": []
}
