{
  "name": "is-greeting",
  "description": "Detects greetings vs other message types.",
  "tags": ["classifier", "intent", "text"],
  "visibility": "public",
  "output_spec": { "type": "boolean" },
  "positives": [
    { "input": "hi there", "expected": true },
    { "input": "hello team", "expected": true },
    { "input": "hey everyone", "expected": true },
    { "input": "good morning", "expected": true },
    { "input": "howdy", "expected": true },
    { "input": "yo whats up", "expected": true },
    { "input": "where is my order", "expected": false },
    { "input": "this is broken", "expected": false },
    { "input": "deploy starts at 3pm", "expected": false },
    { "input": "merge conflict in main", "expected": false }
  ]
}
