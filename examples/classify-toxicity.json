{
  "name": "classify-toxicity",
  "description": "Binary toxicity classifier for short comments.",
  "tags": ["classifier", "demo", "moderation"],
  "visibility": "public",
  "output_spec": { "type": "boolean" },
  "positives": [
    { "input": "you are stupid and worthless", "expected": true },
    { "input": "shut up idiot",                 "expected": true },
    { "input": "hate this loser",               "expected": true },
    { "input": "thanks for the help today",     "expected": false },
    { "input": "great work on the launch",      "expected": false },
    { "input": "let's grab lunch at noon",      "expected": false },
    { "input": "appreciate the review",         "expected": false }
  ],
  "negatives": [
    { "input": "your code is excellent", "expected_not": true }
  ]
}
