{
  "name": "classify-priority",
  "description": "Three-class issue priority: low, medium, high.",
  "tags": ["classifier", "triage", "ops"],
  "visibility": "public",
  "output_spec": { "type": "enum", "values": ["low", "medium", "high"] },
  "positives": [
    { "input": "production database is down", "expected": "high" },
    { "input": "all users seeing 500 errors", "expected": "high" },
    { "input": "site completely unreachable now", "expected": "high" },
    { "input": "critical security vulnerability", "expected": "high" },
    { "input": "checkout failing for premium users", "expected": "medium" },
    { "input": "search results slower than usual", "expected": "medium" },
    { "input": "intermittent timeout on api endpoint", "expected": "medium" },
    { "input": "minor styling glitch on settings page", "expected": "low" },
    { "input": "typo in onboarding email", "expected": "low" },
    { "input": "icon misaligned in footer", "expected": "low" }
  ]
}
