{
  "name": "mentions-time",
  "description": "Flags messages that reference clock times or schedule words.",
  "tags": ["classifier", "scheduling", "extractor"],
  "visibility": "public",
  "output_spec": { "type": "boolean" },
  "positives": [
    { "input": "lets meet at 3pm tomorrow", "expected": true },
    { "input": "deploy starts at noon today", "expected": true },
    { "input": "call you in 5 minutes", "expected": true },
    { "input": "scheduling for monday morning", "expected": true },
    { "input": "tonight after dinner works", "expected": true },
    { "input": "next week sometime please", "expected": true },
    { "input": "the build is broken", "expected": false },
    { "input": "great work on the launch", "expected": false },
    { "input": "merging the PR now", "expected": false },
    { "input": "shipped the feature", "expected": false }
  ]
}
