{
  "name": "count-chars",
  "description": "Returns the character count of an input string.",
  "tags": ["counter", "text"],
  "visibility": "public",
  "output_spec": { "type": "integer" },
  "positives": [
    { "input": "hi", "expected": 2 },
    { "input": "hello", "expected": 5 },
    { "input": "hello world", "expected": 11 },
    { "input": "the quick brown fox", "expected": 19 },
    { "input": "a", "expected": 1 },
    { "input": "abcdefghij", "expected": 10 }
  ]
}
