{
  "name": "is-question",
  "description": "Detects whether a short text is a question.",
  "tags": ["classifier", "text", "intent"],
  "visibility": "public",
  "output_spec": { "type": "boolean" },
  "positives": [
    { "input": "what time does the meeting start", "expected": true },
    { "input": "where is my order", "expected": true },
    { "input": "how do I reset my password", "expected": true },
    { "input": "why is the build failing", "expected": true },
    { "input": "when will the feature ship", "expected": true },
    { "input": "who owns this dashboard", "expected": true },
    { "input": "can you take a look", "expected": true },
    { "input": "is the deploy done", "expected": true },
    { "input": "please review the PR", "expected": false },
    { "input": "deploy starts at 3pm", "expected": false },
    { "input": "thanks for the help", "expected": false },
    { "input": "merging now", "expected": false }
  ]
}
