{
  "name": "mentions-money",
  "description": "Flags messages that mention money, prices, or payments.",
  "tags": ["classifier", "finance", "extractor"],
  "visibility": "public",
  "output_spec": { "type": "boolean" },
  "positives": [
    { "input": "the total was $129 plus tax", "expected": true },
    { "input": "wire $5000 by friday", "expected": true },
    { "input": "subscription is $9 per month", "expected": true },
    { "input": "invoice for 1200 USD attached", "expected": true },
    { "input": "venmo me 50 bucks", "expected": true },
    { "input": "refund the payment please", "expected": true },
    { "input": "lunch tomorrow at noon", "expected": false },
    { "input": "deploy starts at 3pm", "expected": false },
    { "input": "please review the PR", "expected": false },
    { "input": "team retro friday morning", "expected": false }
  ]
}
