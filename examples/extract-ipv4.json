{
  "name": "extract-ipv4",
  "description": "Extracts IPv4 addresses from arbitrary text.",
  "tags": ["extractor", "network", "logs"],
  "visibility": "public",
  "output_spec": { "type": "string[]", "pattern": "ipv4" },
  "positives": [
    { "input": "client connected from 192.168.1.42 at 03:14", "expected": ["192.168.1.42"] },
    { "input": "blocked 10.0.0.5 and 8.8.8.8 today", "expected": ["10.0.0.5", "8.8.8.8"] },
    { "input": "server is at 172.16.32.100", "expected": ["172.16.32.100"] },
    { "input": "no ip in this line", "expected": [] }
  ]
}
