{
  "name": "is-positive-review",
  "description": "Binary positive vs negative product review classifier.",
  "tags": ["classifier", "sentiment", "ecommerce"],
  "visibility": "public",
  "output_spec": { "type": "boolean" },
  "positives": [
    { "input": "love this product, totally worth it", "expected": true },
    { "input": "amazing quality, would buy again", "expected": true },
    { "input": "exceeded my expectations, fantastic", "expected": true },
    { "input": "perfect fit, very happy", "expected": true },
    { "input": "great value, highly recommend", "expected": true },
    { "input": "absolutely terrible, broke after a week", "expected": false },
    { "input": "waste of money, awful experience", "expected": false },
    { "input": "hated it, returning immediately", "expected": false },
    { "input": "poor quality, very disappointed", "expected": false },
    { "input": "would not recommend, save your money", "expected": false }
  ]
}
