{
  "name": "detect-pii",
  "description": "Flags messages that contain PII (email, phone, etc).",
  "tags": ["classifier", "moderation", "privacy"],
  "visibility": "public",
  "output_spec": { "type": "boolean" },
  "positives": [
    { "input": "contact me at jane@example.com", "expected": true },
    { "input": "phone number 555-123-4567", "expected": true },
    { "input": "ssn 123-45-6789", "expected": true },
    { "input": "john.doe@gmail.com is the address", "expected": true },
    { "input": "call 4155551212 anytime", "expected": true },
    { "input": "lunch tomorrow at noon", "expected": false },
    { "input": "deploy starts at three pm", "expected": false },
    { "input": "the build finished cleanly", "expected": false },
    { "input": "shipping the feature today", "expected": false }
  ]
}
