{
  "name": "classify-language",
  "description": "Coarse language detector: english, spanish, french.",
  "tags": ["classifier", "language", "i18n"],
  "visibility": "public",
  "output_spec": { "type": "enum", "values": ["english", "spanish", "french"] },
  "positives": [
    { "input": "the meeting is at three", "expected": "english" },
    { "input": "where is the train station", "expected": "english" },
    { "input": "thank you very much", "expected": "english" },
    { "input": "please send the invoice", "expected": "english" },
    { "input": "donde esta la estacion", "expected": "spanish" },
    { "input": "muchas gracias por tu ayuda", "expected": "spanish" },
    { "input": "el partido empieza a las tres", "expected": "spanish" },
    { "input": "por favor envia la factura", "expected": "spanish" },
    { "input": "ou est la gare", "expected": "french" },
    { "input": "merci beaucoup pour ton aide", "expected": "french" },
    { "input": "le match commence a trois heures", "expected": "french" },
    { "input": "envoyez la facture s il vous plait", "expected": "french" }
  ]
}
