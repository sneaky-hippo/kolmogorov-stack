{
  "name": "extract-urls",
  "description": "Pulls every HTTP/HTTPS URL out of free text.",
  "tags": ["extractor", "demo", "url"],
  "visibility": "public",
  "output_spec": { "type": "string[]", "pattern": "url" },
  "positives": [
    { "input": "see https://example.com and http://foo.bar/baz", "expected": ["https://example.com", "http://foo.bar/baz"] },
    { "input": "no link here", "expected": [] },
    { "input": "ref: https://docs.kolmogorov.dev/v1/synthesize?ref=demo", "expected": ["https://docs.kolmogorov.dev/v1/synthesize?ref=demo"] }
  ],
  "negatives": []
}
