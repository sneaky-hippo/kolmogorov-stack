{
  "name": "classify-formality",
  "description": "Two-class formality: formal vs casual register.",
  "tags": ["classifier", "style", "writing"],
  "visibility": "public",
  "output_spec": { "type": "enum", "values": ["formal", "casual"] },
  "positives": [
    { "input": "Dear sir, I am writing to inquire about your services", "expected": "formal" },
    { "input": "Please find attached the executed contract", "expected": "formal" },
    { "input": "Pursuant to our agreement we shall proceed", "expected": "formal" },
    { "input": "I would be grateful if you could review", "expected": "formal" },
    { "input": "Sincerely yours", "expected": "formal" },
    { "input": "yo what's up", "expected": "casual" },
    { "input": "lol no way that's wild", "expected": "casual" },
    { "input": "gonna grab lunch wanna come", "expected": "casual" },
    { "input": "haha that's hilarious", "expected": "casual" },
    { "input": "idk maybe later tho", "expected": "casual" }
  ]
}
