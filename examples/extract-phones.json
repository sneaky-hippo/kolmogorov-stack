{
  "name": "extract-phones",
  "description": "Pulls phone numbers out of free text.",
  "tags": ["extractor", "demo", "phone"],
  "visibility": "public",
  "output_spec": { "type": "string[]", "pattern": "phone" },
  "positives": [
    { "input": "call me at 555-123-4567 or 415.555.0199", "expected": ["555-123-4567", "415.555.0199"] },
    { "input": "international: +1 (415) 555-0199", "expected": ["+1 (415) 555-0199"] },
    { "input": "no phone here", "expected": [] }
  ],
  "negatives": []
}
