{
  "name": "is-spam",
  "description": "Binary spam classifier for short messages.",
  "tags": ["classifier", "demo", "text"],
  "visibility": "public",
  "output_spec": { "type": "boolean" },
  "positives": [
    { "input": "FREE viagra click here NOW", "expected": true },
    { "input": "URGENT — claim your prize today!!!", "expected": true },
    { "input": "WIN a free iPhone, link inside", "expected": true },
    { "input": "💰💰 EARN $500/day from home", "expected": true },
    { "input": "Lunch tomorrow at noon?", "expected": false },
    { "input": "Project sync at 3pm Friday", "expected": false },
    { "input": "Can you review the PR later?", "expected": false },
    { "input": "Heads up: deploy at 2", "expected": false }
  ],
  "negatives": [
    { "input": "team retro Friday", "expected_not": true }
  ]
}
