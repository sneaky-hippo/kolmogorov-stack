{
  "name": "is-command",
  "description": "Detects imperative commands vs declarative statements.",
  "tags": ["classifier", "intent", "instructions"],
  "visibility": "public",
  "output_spec": { "type": "boolean" },
  "positives": [
    { "input": "deploy the service now", "expected": true },
    { "input": "rollback the migration please", "expected": true },
    { "input": "run the tests immediately", "expected": true },
    { "input": "merge that PR today", "expected": true },
    { "input": "delete the stale branches", "expected": true },
    { "input": "restart the worker pool", "expected": true },
    { "input": "the build finished successfully", "expected": false },
    { "input": "we shipped the feature yesterday", "expected": false },
    { "input": "the deploy was clean", "expected": false },
    { "input": "everything is working fine", "expected": false }
  ]
}
