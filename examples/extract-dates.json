{
  "name": "extract-dates",
  "description": "Pulls ISO and slash-format dates out of text.",
  "tags": ["extractor", "demo", "date"],
  "visibility": "public",
  "output_spec": { "type": "string[]", "pattern": "date" },
  "positives": [
    { "input": "deployed on 2026-04-12 and rolled back 4/15/2026", "expected": ["2026-04-12", "4/15/2026"] },
    { "input": "see you 12/31/25", "expected": ["12/31/25"] },
    { "input": "no date present", "expected": [] }
  ],
  "negatives": []
}
