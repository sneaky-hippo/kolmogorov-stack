{
  "name": "kolmogorov-stack",
  "version": "0.2.2",
  "description": "kolm - the private AI compiler. Compile your task into a .kolm artifact, trained on your data, that runs on your hardware.",
  "private": true,
  "type": "module",
  "main": "server.js",
  "bin": {
    "kolm": "cli/kolm.js"
  },
  "scripts": {
    "start": "node scripts/build-sdk-version.js && node server.js",
    "dev": "node scripts/build-sdk-version.js && node --watch server.js",
    "seed": "node scripts/seed.js",
    "demo": "node scripts/demo.js",
    "build:sdk": "node scripts/build-sdk-version.js",
    "assets:fal": "node scripts/fal_generate_aurora.mjs",
    "lint:refs": "node scripts/audit-static-refs.cjs && node scripts/audit-href.cjs --strict",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "adm-zip": "^0.5.17",
    "archiver": "^7.0.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "cli/",
    "src/",
    "services/",
    "sdk/",
    "scripts/build-sdk-version.js",
    "server.js",
    "README.md",
    "LICENSE"
  ]
}
