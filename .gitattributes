# default: detect text vs binary, normalize text to LF in the repo
* text=auto eol=lf

# scripts and source — always LF (shebang lines break on Mac/Linux with CRLF)
*.sh    text eol=lf
*.bash  text eol=lf
*.py    text eol=lf
*.pl    text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.cjs   text eol=lf
*.ts    text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.toml  text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.md    text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf

# binaries — never touch
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.svg   text eol=lf
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.kolm  binary
