ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
PORT=8787
ADMIN_KEY=ks_admin_change_me
DEFAULT_TENANT=demo

# Required in production. Receipts + .kolm signatures are HMAC-SHA256 under
# this secret. Rotating invalidates every receipt and signature ever minted,
# so set once and keep it stable. Generate with:
#   node -e "console.log('ks_receipt_' + require('crypto').randomBytes(24).toString('hex'))"
RECIPE_RECEIPT_SECRET=
