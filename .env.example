ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
PORT=8787
DEFAULT_TENANT=demo
# Required in production-like hosts. Both paths must exist and be writable.
KOLM_DATA_DIR=
KOLM_ARTIFACT_DIR=
KOLM_RECALL_ROOT=

# Production store. Use sqlite for deploys; JSON is kept for local development
# and explicitly temporary single-node deployments only.
KOLM_STORE_DRIVER=sqlite
KOLM_DB_PATH=
KOLM_ALLOW_JSON_STORE=false
INVITE_ONLY=false
RATE_LIMIT_PER_SEC=20
RATE_LIMIT_BURST=60

# Optional in development. Required for admin routes in production.
# Generate with:
#   node -e "console.log('ks_admin_' + require('crypto').randomBytes(24).toString('hex'))"
ADMIN_KEY=

# Required in production. Must be at least 32 characters. Receipts + .kolm
# signatures are HMAC-SHA256 under this secret. Rotating invalidates every
# receipt and signature ever minted, so set once and keep it stable. Generate with:
#   node -e "console.log('ks_receipt_' + require('crypto').randomBytes(24).toString('hex'))"
RECIPE_RECEIPT_SECRET=

# Public uptime check: GET /health.
# Deploy readiness gate: GET /ready. In production-like hosts, /ready returns
# 503 until RECIPE_RECEIPT_SECRET is strong, KOLM_STORE_DRIVER is sqlite
# (unless KOLM_ALLOW_JSON_STORE=true), and data/artifact dirs are writable.

# ---- Stripe billing ------------------------------------------------------
# Required for paid plans. Without these, /v1/signup with a paid plan and
# /v1/account/change-plan to a paid plan return 503 billing_not_configured
# and the tenant stays on the free tier.
#
# Each Payment Link must be set up in the Stripe dashboard with the matching
# monthly price ($9 / $49 / $149 / $1,499 / $2,999) and Allow promotion code +
# Collect customer address as preferred. The plan is identified by the
# `amount_total` field on the Checkout Session, so each Link must charge the
# canonical price exactly.
STRIPE_PAYMENT_LINK_STARTER=
STRIPE_PAYMENT_LINK_PRO=
STRIPE_PAYMENT_LINK_TEAMS=
STRIPE_PAYMENT_LINK_BUSINESS=
STRIPE_PAYMENT_LINK_ENT=

# Stripe webhook signing secret (whsec_...). Required for the /v1/stripe/webhook
# endpoint to verify signatures and flip plans on `checkout.session.completed`.
# Provision in Stripe dashboard > Developers > Webhooks > Add endpoint
# pointing at https://<your-domain>/v1/stripe/webhook with at least these
# events: checkout.session.completed, customer.subscription.deleted,
# invoice.payment_failed.
STRIPE_WEBHOOK_SECRET=
