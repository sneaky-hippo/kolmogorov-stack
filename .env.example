ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
PORT=8787
DEFAULT_TENANT=demo
# Required in production-like hosts. Both paths must exist and be writable.
KOLM_DATA_DIR=
KOLM_ARTIFACT_DIR=
KOLM_RECALL_ROOT=

# Production store. Use sqlite for deploys; JSON is kept for local development
# and explicitly temporary single-node deployments only.
KOLM_STORE_DRIVER=sqlite
KOLM_DB_PATH=
KOLM_ALLOW_JSON_STORE=false
INVITE_ONLY=false
RATE_LIMIT_PER_SEC=20
RATE_LIMIT_BURST=60

# Optional in development. Required for admin routes in production.
# Generate with:
#   node -e "console.log('ks_admin_' + require('crypto').randomBytes(24).toString('hex'))"
ADMIN_KEY=

# Required in production. Must be at least 32 characters. Receipts + .kolm
# signatures are HMAC-SHA256 under this secret. Rotating invalidates every
# receipt and signature ever minted, so set once and keep it stable. Generate with:
#   node -e "console.log('ks_receipt_' + require('crypto').randomBytes(24).toString('hex'))"
RECIPE_RECEIPT_SECRET=

# Public uptime check: GET /health.
# Deploy readiness gate: GET /ready. In production-like hosts, /ready returns
# 503 until RECIPE_RECEIPT_SECRET is strong, KOLM_STORE_DRIVER is sqlite
# (unless KOLM_ALLOW_JSON_STORE=true), and data/artifact dirs are writable.

# ---- Stripe billing ------------------------------------------------------
# Required for paid plans. Without these, /v1/signup with a paid plan and
# /v1/account/change-plan to a paid plan return 503 billing_not_configured
# and the tenant stays on the free tier.
#
# Each Payment Link must be set up in the Stripe dashboard with the matching
# monthly price ($9 / $49 / $149 / $1,499 / $2,999) and Allow promotion code +
# Collect customer address as preferred. The plan is identified by the
# `amount_total` field on the Checkout Session, so each Link must charge the
# canonical price exactly.
STRIPE_PAYMENT_LINK_STARTER=
STRIPE_PAYMENT_LINK_PRO=
STRIPE_PAYMENT_LINK_TEAMS=
STRIPE_PAYMENT_LINK_BUSINESS=
STRIPE_PAYMENT_LINK_ENT=

# Stripe webhook signing secret (whsec_...). Required for the /v1/stripe/webhook
# endpoint to verify signatures and flip plans on `checkout.session.completed`.
# Provision in Stripe dashboard > Developers > Webhooks > Add endpoint
# pointing at https://<your-domain>/v1/stripe/webhook with at least these
# events: checkout.session.completed, customer.subscription.updated,
# customer.subscription.deleted, invoice.payment_failed.
STRIPE_WEBHOOK_SECRET=

# Stripe secret key (sk_live_...). Required only for /v1/account/delete to
# auto-cancel an active Stripe subscription on account deletion. Without it,
# deletion still works but the user has to cancel from their bank or Stripe.
STRIPE_SECRET_KEY=

# ---- OAuth (Google + GitHub) -------------------------------------------
# Each provider is optional. The /signup page hides the buttons for any
# provider that isn't configured. Set both _CLIENT_ID and _CLIENT_SECRET
# for a provider to enable it.
#
# Google: https://console.cloud.google.com/apis/credentials
#   1. Create project (or pick existing)
#   2. APIs & Services -> Credentials -> Create OAuth client ID
#   3. Application type: Web application
#   4. Authorized redirect URIs: https://kolm.ai/v1/oauth/google/callback
#   5. Copy client_id + client_secret here
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# GitHub: https://github.com/settings/developers -> New OAuth App
#   Homepage URL:               https://kolm.ai
#   Authorization callback URL: https://kolm.ai/v1/oauth/github/callback
#   Copy Client ID + Generate Client Secret
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Where the OAuth callbacks redirect back to. Default https://kolm.ai.
# Set to your custom domain if hosting elsewhere.
OAUTH_REDIRECT_BASE=https://kolm.ai

# ---- Email (transactional) ----------------------------------------------
# Optional but strongly recommended for paid customers — Stripe webhook events
# trigger welcome / activation / failed-payment emails.
#
# Resend (https://resend.com) is the easiest path:
#   1. Sign up with Google
#   2. Add a domain (kolm.ai) and copy the DNS records
#   3. Create an API key at https://resend.com/api-keys
#   4. Set RESEND_API_KEY=re_... and EMAIL_FROM="kolm <hello@kolm.ai>"
#
# Without these set, sendMail() returns { skipped: true } silently — every
# email path is best-effort and never blocks user requests.
RESEND_API_KEY=
EMAIL_FROM="kolm <hello@kolm.ai>"
EMAIL_REPLY_TO=
