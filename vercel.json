{
  "version": 2,
  "rewrites": [
    { "source": "/health", "destination": "/api" },
    { "source": "/v1/(.*)", "destination": "/api" },
    { "source": "/", "destination": "/index.html" },
    { "source": "/compile", "destination": "/compile.html" },
    { "source": "/run", "destination": "/run.html" },
    { "source": "/recall", "destination": "/recall.html" },
    { "source": "/cloud", "destination": "/cloud.html" },
    { "source": "/manual", "destination": "/manual.html" },
    { "source": "/account", "destination": "/account.html" },
    { "source": "/signup", "destination": "/signup.html" },
    { "source": "/mobile", "destination": "/mobile.html" },
    { "source": "/pricing", "destination": "/pricing.html" },
    { "source": "/status", "destination": "/status.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/playground", "destination": "/playground.html" },
    { "source": "/docs", "destination": "/docs.html" },
    { "source": "/registry", "destination": "/registry.html" },
    { "source": "/atlas", "destination": "/registry.html" },
    { "source": "/device", "destination": "/device.html" },
    { "source": "/onboarding", "destination": "/onboarding.html" },
    { "source": "/security", "destination": "/security.html" },
    { "source": "/signin", "destination": "/signup.html" },
    { "source": "/serve", "destination": "/serve.html" },
    { "source": "/anatomy", "destination": "/anatomy.html" },
    { "source": "/k-score", "destination": "/k-score.html" },
    { "source": "/quickstart", "destination": "/quickstart.html" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/manifesto", "destination": "/manifesto.html" },
    { "source": "/healthcare", "destination": "/healthcare.html" },
    { "source": "/finance", "destination": "/finance.html" },
    { "source": "/defense", "destination": "/defense.html" },
    { "source": "/changelog", "destination": "/changelog.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/why", "destination": "/why.html" },
    { "source": "/articles", "destination": "/articles/index.html" },
    { "source": "/articles/(.*)", "destination": "/articles/$1.html" }
  ],
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "{public/**,data/**,examples/**,src/**}"
    }
  }
}
